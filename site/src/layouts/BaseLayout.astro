---
import { content, GITHUB_URL, locales, type Locale } from "../data/site";
import "../styles/global.css";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  canonicalPath: string;
  alternatePath?: string;
  jsonLd: unknown[];
}

const { locale, title, description, canonicalPath, alternatePath, jsonLd } = Astro.props;
const t = content[locale];
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://qwake.top";
const canonical = `${siteUrl}${canonicalPath}`;
const alternateLocale = locale === "en" ? "zh-CN" : "en";
const resolvedAlternatePath = alternatePath ?? locales[alternateLocale].path;
const ogImage = `${siteUrl}/og-image.svg`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<!doctype html>
<html lang={locales[locale].htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang={alternateLocale} href={`${siteUrl}${resolvedAlternatePath}`} />
    <link rel="alternate" hreflang="x-default" href={locale === "en" ? canonical : `${siteUrl}${resolvedAlternatePath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Qwake" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {
      gaId && (
        <>
          <link rel="preconnect" href="https://www.googletagmanager.com" />
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}
          />
        </>
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header>
      <nav class="wrap" aria-label="Main">
        <a class="brand" href={locales[locale].path} aria-label="Qwake home">Qwake</a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
        <label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle navigation">
          <span class="hamburger"></span>
        </label>
        <div class="navlinks">
          <a href="#features">{t.nav.features}</a>
          <a href="#install">{t.nav.install}</a>
          <a href="#schedule">{t.nav.schedule}</a>
          <a href={locale === "en" ? "/blog/" : "/zh-CN/blog/"}>{t.nav.blog}</a>
          <a href="#faq">{t.nav.faq}</a>
          <a href={GITHUB_URL}>{t.nav.github}</a>
        </div>
        <div class="langs">
          <a aria-current={locale === "en" ? "page" : undefined} href={locale === "en" ? canonicalPath : resolvedAlternatePath}>EN</a>
          <a aria-current={locale === "zh-CN" ? "page" : undefined} href={locale === "zh-CN" ? canonicalPath : resolvedAlternatePath}>中文</a>
        </div>
      </nav>
    </header>
    <slot />
  </body>
</html>
